# ─── GitReport API — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ── Frontend URL (for CORS + OAuth redirect) ─────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────────
# Neon: postgres://user:pass@host/dbname?sslmode=require
# Local: postgres://postgres:password@localhost:5432/gitreport
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash: rediss://default:password@hostname:6380
# Local: redis://localhost:6379
REDIS_URL=

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Token Encryption ─────────────────────────────────────────────────────────
# AES-256 key: MUST be exactly 64 hex characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── Anthropic (Claude API) ───────────────────────────────────────────────────
# Model: claude-haiku-4-5 (~$0.001/report at scale)
ANTHROPIC_API_KEY=
