# API
DATABASE_URL=postgresql://user:password@host:5432/gitreport
REDIS_URL=redis://default:password@host:6379
SESSION_SECRET=minimum-32-character-random-string
ENCRYPTION_KEY=minimum-32-character-random-string
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GEMINI_API_KEY=your_google_ai_studio_key
FRONTEND_URL=https://your-app.vercel.app
PORT=3000

# Email (Resend — https://resend.com)
# Free tier: 3,000/month, 100/day
# Dev: use RESEND_FROM_EMAIL=onboarding@resend.dev (no domain verification needed)
# Prod: swap to a verified sending domain
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# Web
VITE_API_URL=https://your-api.railway.app
